<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Administrasi Kurikulum 2026/2027</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js for beautiful visuals -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        /* Custom Scrollbar for matrix grids */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

    <!-- React App Root -->
    <div id="root" class="flex-grow flex flex-col"></div>

    <!-- React and ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <!-- Firebase SDK Modules -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, getDoc, setDoc, updateDoc, collection, onSnapshot, addDoc, deleteDoc, query } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        window.firebaseModules = {
            initializeApp,
            getAuth,
            signInAnonymously,
            signInWithCustomToken,
            onAuthStateChanged,
            getFirestore,
            doc,
            getDoc,
            setDoc,
            updateDoc,
            collection,
            onSnapshot,
            addDoc,
            deleteDoc,
            query
        };
    </script>

    <!-- React Application Logic -->
    <script type="text/babel">
        const { useState, useEffect, useMemo, useRef } = React;

        // Master Data Guru
        const TEACHERS = [
            "Rosalia Aristiati", "Alfiah", "Endang Sulistyaningsih", "Mahrudi", "Abdul Wakhid",
            "Rita Widjajanti", "Sri Wahyuni", "Sri Jamiati", "Wahyuning Tias", "Ida Rosida",
            "Sri Sihniyati", "Anita Widyastuti", "Ira Yuliani Kusumaningrum", "Hartini",
            "Ely Nilawati", "Niken Wulandari", "Sri Hidayati A.S", "Neti Diyah Pancaningrum",
            "Agustin Giri Hapsari", "Solikin", "Andika Kusumawati", "Nor Hamidah",
            "Istining Muntikah", "Sri Kadarsih", "Sri Winda Agustina Wibowo", "Sujiyah",
            "Scripzyan Meifany Ariyadi Nk", "Umi Fahruroh", "Aries Trian Pradestira",
            "Mar'atush Sholihah R", "Moh Nurman Salikul Ihsan", "Ahmad Dliyaul Haq",
            "Istiqomah Novitaningrum", "Fridha Fadhlurrahma", "Devia Kristianti",
            "Dwi Nur Hidayah", "Marita Riski Prastya", "Yuliyanto, S.Pd", "Yulianto",
            "Kautsar Julia Jasmine", "Nanik Widarti"
        ].sort();

        // Master Data Mapel
        const SUBJECTS = [
            "Pendidikan Agama Islam", "Pendidikan Agama Kristen", "Bahasa Indonesia",
            "IPA", "IPS", "Bahasa Jawa", "Seni dan Prakarya", "Bahasa Inggris",
            "KKA", "PJOK", "Matematika", "Pendidikan Pancasila", "Informatika", "Bimbingan Konseling"
        ].sort();

        // Wali Kelas Mapping
        const HOMEROOM_MAP = {
            "7A": "Sujiyah",
            "7B": "Mar'atush Sholihah R",
            "7C": "Agustin Giri Hapsari",
            "7D": "Dwi Nur Hidayah",
            "7E": "Niken Wulandari",
            "7F": "Yuliyanto, S.Pd",
            "7G": "Hartini",
            "7H": "Fridha Fadhlurrahma",
            "8A": "Neti Diyah Pancaningrum",
            "8B": "Istining Muntikah",
            "8C": "Ahmad Dliyaul Haq",
            "8D": "Marita Riski Prastya",
            "8E": "Sri Wahyuni",
            "8F": "Umi Fahruroh",
            "8G": "Rita Widjajanti",
            "8H": "Sri Hidayati A.S",
            "9A": "Devia Kristianti",
            "9B": "Nor Hamidah",
            "9C": "Sri Kadarsih",
            "9D": "Ira Yuliani Kusumaningrum",
            "9E": "Wahyuning Tias",
            "9F": "Sri Jamiati",
            "9G": "Istiqomah Novitaningrum",
            "9H": "Ida Rosida"
        };

        const CLASSES = Object.keys(HOMEROOM_MAP).sort();

        // Weeks Option (1 to 40)
        const WEEKS = Array.from({ length: 40 }, (_, i) => `Minggu ${i + 1}`);

        // Months Option
        const MONTHS = [
            "Juli 2026", "Agustus 2026", "September 2026", "Oktober 2026", "November 2026", "Desember 2026",
            "Januari 2027", "Februari 2027", "Maret 2027", "April 2027", "Mei 2027", "Juni 2027"
        ];

        function App() {
            const [db, setDb] = useState(null);
            const [auth, setAuth] = useState(null);
            const [user, setUser] = useState(null);
            const [loading, setLoading] = useState(true);
            const [saving, setSaving] = useState(false);

            // App State
            const [submissions, setSubmissions] = useState([]);
            const [adminPin, setAdminPin] = useState("2026"); // Default PIN
            const [isUnlocked, setIsUnlocked] = useState(false);
            const [showPinModal, setShowPinModal] = useState(false);
            const [pinInput, setPinInput] = useState("");
            const [pinError, setPinError] = useState("");
            const [showSettingsModal, setShowSettingsModal] = useState(false);
            const [newPinInput, setNewPinInput] = useState("");

            // Navigation Tab
            const [currentTab, setCurrentTab] = useState("overview"); // overview, perangkat, jurnal_mengajar, jurnal_walikelas, jurnal_kelas

            // Form Inputs
            const [formType, setFormType] = useState("perangkat"); // perangkat, jurnal_mengajar, jurnal_walikelas, jurnal_kelas
            const [formTeacher, setFormTeacher] = useState("");
            const [formSubject, setFormSubject] = useState("");
            const [formClass, setFormClass] = useState("");
            const [formPeriod, setFormPeriod] = useState("Tahun Ajaran 2026/2027");
            const [formStatus, setFormStatus] = useState("Sudah");
            const [formNotes, setFormNotes] = useState("");

            // Filter States
            const [filterTeacher, setFilterTeacher] = useState("");
            const [filterClass, setFilterClass] = useState("");
            const [filterSubject, setFilterSubject] = useState("");
            const [filterStatus, setFilterStatus] = useState("");
            const [searchTerm, setSearchTerm] = useState("");

            // UI Toast
            const [toast, setToast] = useState(null);

            // Chart Reference
            const chartRef = useRef(null);
            const chartInstance = useRef(null);

            const showToast = (message, type = "success") => {
                setToast({ message, type });
                setTimeout(() => setToast(null), 4000);
            };

            useEffect(() => {
                const initFirebase = async () => {
                    try {
                        const { initializeApp, getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged, getFirestore } = window.firebaseModules;
                        
                        // Fallback Configuration
                        const appId = typeof __app_id !== 'undefined' ? __app_id : 'kurikulum-admin-dashboard';
                        const firebaseConfig = typeof __firebase_config !== 'undefined' 
                            ? JSON.parse(__firebase_config) 
                            : {
                                apiKey: "mock-api-key",
                                authDomain: "mock-auth-domain",
                                projectId: "mock-project-id",
                                storageBucket: "mock-storage-bucket",
                                messagingSenderId: "mock-sender-id",
                                appId: "mock-app-id"
                            };

                        const app = initializeApp(firebaseConfig);
                        const firestoreDb = getFirestore(app);
                        const firebaseAuth = getAuth(app);

                        setDb(firestoreDb);
                        setAuth(firebaseAuth);

                        // Authentication Flow (Rule 3: Auth Before Queries)
                        let currentUser = null;
                        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                            try {
                                const userCredential = await signInWithCustomToken(firebaseAuth, __initial_auth_token);
                                currentUser = userCredential.user;
                            } catch (authErr) {
                                console.warn("Failed custom token auth, trying anonymous...", authErr);
                                const userCredential = await signInAnonymously(firebaseAuth);
                                currentUser = userCredential.user;
                            }
                        } else {
                            const userCredential = await signInAnonymously(firebaseAuth);
                            currentUser = userCredential.user;
                        }

                        setUser(currentUser);

                        // Submissions Path: /artifacts/{appId}/public/data/submissions
                        const { collection, onSnapshot, doc, getDoc, setDoc } = window.firebaseModules;
                        
                        const submissionsPath = `/artifacts/${appId}/public/data/submissions`;
                        const settingsPath = `/artifacts/${appId}/public/data/settings`;

                        // Load Custom PIN
                        const pinDocRef = doc(firestoreDb, settingsPath, "pin_config");
                        const pinSnap = await getDoc(pinDocRef);
                        if (pinSnap.exists()) {
                            setAdminPin(pinSnap.data().pin || "2026");
                        } else {
                            // Write default pin on first run
                            await setDoc(pinDocRef, { pin: "2026" }, { merge: true });
                        }

                        // Listen to real-time updates for submissions
                        const submissionsCol = collection(firestoreDb, submissionsPath);
                        const unsubscribe = onSnapshot(submissionsCol, (snapshot) => {
                            const list = [];
                            snapshot.forEach((doc) => {
                                list.push({ id: doc.id, ...doc.data() });
                            });
                            setSubmissions(list);
                            setLoading(false);
                        }, (error) => {
                            console.error("Firestore loading error:", error);
                            showToast("Gagal menyinkronkan data dengan server. Menggunakan database lokal.", "error");
                            setLoading(false);
                        });

                        return () => unsubscribe();
                    } catch (err) {
                        console.error("Firebase init failed, running on mock mode:", err);
                        setLoading(false);
                        showToast("Menjalankan aplikasi dalam mode demo offline.", "info");
                    }
                };

                initFirebase();
            }, []);

            // Auto-fill Teacher if Jurnal Wali Kelas is selected and Class changes
            useEffect(() => {
                if (formType === "jurnal_walikelas" && formClass) {
                    const mappedTeacher = HOMEROOM_MAP[formClass];
                    if (mappedTeacher) {
                        setFormTeacher(mappedTeacher);
                    }
                }
            }, [formType, formClass]);

            // Adjust default period based on administration type selection
            useEffect(() => {
                if (formType === "perangkat") {
                    setFormPeriod("Tahun Ajaran 2026/2027");
                } else if (formType === "jurnal_mengajar" || formType === "jurnal_kelas") {
                    setFormPeriod("Minggu 1");
                } else if (formType === "jurnal_walikelas") {
                    setFormPeriod("Juli 2026");
                }
            }, [formType]);

            const handleUnlock = (e) => {
                e.preventDefault();
                if (pinInput === adminPin) {
                    setIsUnlocked(true);
                    setShowPinModal(false);
                    setPinInput("");
                    setPinError("");
                    showToast("Sesi Kurikulum Berhasil Dibuka! Anda dapat melakukan input.", "success");
                } else {
                    setPinError("PIN yang Anda masukkan salah. Silakan coba lagi.");
                }
            };

            const handleLock = () => {
                setIsUnlocked(false);
                showToast("Sesi Kurikulum Terkunci kembali.", "info");
            };

            const handleUpdatePin = async (e) => {
                e.preventDefault();
                if (!newPinInput || newPinInput.trim().length < 4) {
                    showToast("PIN baru minimal harus terdiri dari 4 digit.", "error");
                    return;
                }

                try {
                    const { doc, setDoc } = window.firebaseModules;
                    const appId = typeof __app_id !== 'undefined' ? __app_id : 'kurikulum-admin-dashboard';
                    const settingsPath = `/artifacts/${appId}/public/data/settings`;
                    
                    if (db) {
                        const pinDocRef = doc(db, settingsPath, "pin_config");
                        await setDoc(pinDocRef, { pin: newPinInput }, { merge: true });
                    }
                    
                    setAdminPin(newPinInput);
                    setShowSettingsModal(false);
                    setNewPinInput("");
                    showToast("PIN Keamanan Berhasil Diubah!", "success");
                } catch (err) {
                    showToast("Gagal menyimpan PIN baru ke server.", "error");
                }
            };

            const handleAddSubmission = async (e) => {
                e.preventDefault();

                if (!isUnlocked) {
                    setShowPinModal(true);
                    return;
                }

                // Validations
                if (!formTeacher) {
                    showToast("Silakan pilih Nama Guru terlebih dahulu.", "error");
                    return;
                }
                if (formType !== "jurnal_walikelas" && formType !== "jurnal_kelas" && !formSubject) {
                    showToast("Silakan pilih Mata Pelajaran terlebih dahulu.", "error");
                    return;
                }
                if (formType !== "perangkat" && !formClass) {
                    showToast("Silakan tentukan Kelas terlebih dahulu.", "error");
                    return;
                }

                setSaving(true);
                const payload = {
                    category: formType,
                    teacher: formTeacher,
                    subject: formType === "jurnal_walikelas" || formType === "jurnal_kelas" ? "" : formSubject,
                    class: formType === "perangkat" ? "" : formClass,
                    period: formPeriod,
                    status: formStatus,
                    notes: formNotes,
                    updatedAt: new Date().toISOString(),
                    updatedBy: user ? user.uid : "Anonymous"
                };

                // Check for existing records to prevent duplicates & overwrite cleanly
                const existingIndex = submissions.findIndex(s => 
                    s.category === payload.category &&
                    s.teacher === payload.teacher &&
                    s.subject === payload.subject &&
                    s.class === payload.class &&
                    s.period === payload.period
                );

                try {
                    const { doc, setDoc, collection, addDoc } = window.firebaseModules;
                    const appId = typeof __app_id !== 'undefined' ? __app_id : 'kurikulum-admin-dashboard';
                    const submissionsPath = `/artifacts/${appId}/public/data/submissions`;

                    if (db) {
                        if (existingIndex >= 0) {
                            // Update existing record
                            const docId = submissions[existingIndex].id;
                            const recordRef = doc(db, submissionsPath, docId);
                            await setDoc(recordRef, payload, { merge: true });
                            showToast("Data administrasi lama berhasil diperbarui secara otomatis!", "success");
                        } else {
                            // Insert new record
                            const colRef = collection(db, submissionsPath);
                            await addDoc(colRef, payload);
                            showToast("Administrasi baru berhasil disimpan!", "success");
                        }
                    } else {
                        // Local fallback simulation
                        if (existingIndex >= 0) {
                            const updated = [...submissions];
                            updated[existingIndex] = { id: submissions[existingIndex].id, ...payload };
                            setSubmissions(updated);
                        } else {
                            setSubmissions([...submissions, { id: Date.now().toString(), ...payload }]);
                        }
                        showToast("Data disimpan ke penyimpanan lokal (Mode Demo).", "success");
                    }

                    // Reset notes only
                    setFormNotes("");
                } catch (err) {
                    console.error("Save error:", err);
                    showToast("Gagal menyimpan data ke database server.", "error");
                } finally {
                    setSaving(false);
                }
            };

            const handleDeleteRecord = async (id) => {
                if (!isUnlocked) {
                    setShowPinModal(true);
                    return;
                }

                if (!confirm("Apakah Anda yakin ingin menghapus data administrasi ini?")) return;

                try {
                    const { doc, deleteDoc } = window.firebaseModules;
                    const appId = typeof __app_id !== 'undefined' ? __app_id : 'kurikulum-admin-dashboard';
                    const submissionsPath = `/artifacts/${appId}/public/data/submissions`;

                    if (db) {
                        const recordRef = doc(db, submissionsPath, id);
                        await deleteDoc(recordRef);
                        showToast("Data administrasi berhasil dihapus.", "success");
                    } else {
                        setSubmissions(submissions.filter(s => s.id !== id));
                        showToast("Data lokal berhasil dihapus.", "success");
                    }
                } catch (err) {
                    showToast("Gagal menghapus data dari server.", "error");
                }
            };

            const handleFastStatusUpdate = async (record, newStatus) => {
                if (!isUnlocked) {
                    setShowPinModal(true);
                    return;
                }

                try {
                    const { doc, setDoc } = window.firebaseModules;
                    const appId = typeof __app_id !== 'undefined' ? __app_id : 'kurikulum-admin-dashboard';
                    const submissionsPath = `/artifacts/${appId}/public/data/submissions`;

                    const updatedPayload = {
                        ...record,
                        status: newStatus,
                        updatedAt: new Date().toISOString()
                    };

                    if (db) {
                        const recordRef = doc(db, submissionsPath, record.id);
                        await setDoc(recordRef, updatedPayload, { merge: true });
                    } else {
                        setSubmissions(submissions.map(s => s.id === record.id ? updatedPayload : s));
                    }
                    showToast(`Status diperbarui menjadi: ${newStatus}`, "success");
                } catch (err) {
                    showToast("Gagal memperbarui status secara cepat.", "error");
                }
            };

            const filteredSubmissions = useMemo(() => {
                return submissions.filter(item => {
                    const matchTeacher = !filterTeacher || item.teacher === filterTeacher;
                    const matchClass = !filterClass || item.class === filterClass;
                    const matchSubject = !filterSubject || item.subject === filterSubject;
                    const matchStatus = !filterStatus || item.status === filterStatus;
                    
                    const queryText = searchTerm.toLowerCase();
                    const matchSearch = !searchTerm || 
                        item.teacher.toLowerCase().includes(queryText) ||
                        (item.subject && item.subject.toLowerCase().includes(queryText)) ||
                        (item.class && item.class.toLowerCase().includes(queryText)) ||
                        item.period.toLowerCase().includes(queryText) ||
                        (item.notes && item.notes.toLowerCase().includes(queryText));

                    return matchTeacher && matchClass && matchSubject && matchStatus && matchSearch;
                });
            }, [submissions, filterTeacher, filterClass, filterSubject, filterStatus, searchTerm]);

            // Analytics Totals
            const statistics = useMemo(() => {
                const totalPerangkatTarget = TEACHERS.length; // target 1 per guru
                const totalJurnalTarget = TEACHERS.length * 40; // target mingguan (40 minggu)
                const totalWaliTarget = CLASSES.length * 12; // 12 bulan
                const totalKelasTarget = CLASSES.length * 40; // 40 minggu

                const perangkatCollected = submissions.filter(s => s.category === "perangkat" && s.status === "Sudah").length;
                const jurnalCollected = submissions.filter(s => s.category === "jurnal_mengajar" && s.status === "Sudah").length;
                const waliCollected = submissions.filter(s => s.category === "jurnal_walikelas" && s.status === "Sudah").length;
                const kelasCollected = submissions.filter(s => s.category === "jurnal_kelas" && s.status === "Sudah").length;

                return {
                    perangkat: { collected: perangkatCollected, target: totalPerangkatTarget, pct: Math.min(100, Math.round((perangkatCollected / totalPerangkatTarget) * 100)) || 0 },
                    jurnal_mengajar: { collected: jurnalCollected, target: totalJurnalTarget, pct: Math.min(100, Math.round((jurnalCollected / totalJurnalTarget) * 100)) || 0 },
                    jurnal_walikelas: { collected: waliCollected, target: totalWaliTarget, pct: Math.min(100, Math.round((waliCollected / totalWaliTarget) * 100)) || 0 },
                    jurnal_kelas: { collected: kelasCollected, target: totalKelasTarget, pct: Math.min(100, Math.round((kelasCollected / totalKelasTarget) * 100)) || 0 }
                };
            }, [submissions]);

            useEffect(() => {
                if (currentTab === "overview" && chartRef.current && !loading) {
                    if (chartInstance.current) {
                        chartInstance.current.destroy();
                    }

                    const ctx = chartRef.current.getContext('2d');
                    chartInstance.current = new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: ['Perangkat Mengajar', 'Jurnal Mengajar', 'Jurnal Wali Kelas', 'Jurnal Kelas'],
                            datasets: [
                                {
                                    label: 'Persentase Pengumpulan (%)',
                                    data: [
                                        statistics.perangkat.pct,
                                        statistics.jurnal_mengajar.pct,
                                        statistics.jurnal_walikelas.pct,
                                        statistics.jurnal_kelas.pct
                                    ],
                                    backgroundColor: [
                                        'rgba(79, 70, 229, 0.8)',  // Indigo
                                        'rgba(16, 185, 129, 0.8)', // Emerald
                                        'rgba(245, 158, 11, 0.8)', // Amber
                                        'rgba(59, 130, 246, 0.8)'  // Blue
                                    ],
                                    borderColor: [
                                        'rgb(79, 70, 229)',
                                        'rgb(16, 185, 129)',
                                        'rgb(245, 158, 11)',
                                        'rgb(59, 130, 246)'
                                    ],
                                    borderWidth: 1.5,
                                    borderRadius: 8
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    max: 100,
                                    ticks: {
                                        callback: value => value + "%"
                                    }
                                }
                            },
                            plugins: {
                                legend: {
                                    display: false
                                }
                            }
                        }
                    });
                }
            }, [currentTab, statistics, loading]);

            return (
                <div className="flex flex-col min-h-screen">
                    
                    {}
                    <header className="bg-slate-900 text-white shadow-xl border-b border-slate-800 sticky top-0 z-40">
                        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
                            
                            {/* Logo & School Context */}
                            <div className="flex items-center gap-3">
                                <div className="p-2.5 bg-gradient-to-br from-indigo-500 to-indigo-700 rounded-xl shadow-md shadow-indigo-500/20">
                                    <i className="fa-solid fa-graduation-cap text-2xl text-white"></i>
                                </div>
                                <div>
                                    <h1 className="text-xl font-extrabold tracking-tight bg-gradient-to-r from-white via-slate-100 to-slate-400 bg-clip-text text-transparent">
                                        ADMIN-SINKRON
                                    </h1>
                                    <p className="text-xs text-indigo-300 font-medium">Dashboard Administrasi Kurikulum • TA 2026/2027</p>
                                </div>
                            </div>

                            {/* Control Actions & Locked/Unlocked Switcher */}
                            <div className="flex flex-wrap items-center gap-3">
                                <button 
                                    onClick={() => setShowSettingsModal(true)}
                                    className="p-2.5 bg-slate-800 text-slate-300 rounded-xl hover:bg-slate-700 transition"
                                    title="Pengaturan PIN"
                                >
                                    <i className="fa-solid fa-cog"></i>
                                </button>

                                {isUnlocked ? (
                                    <div className="flex items-center gap-2 bg-emerald-950/60 border border-emerald-500/30 text-emerald-300 px-4 py-2 rounded-xl text-sm font-semibold shadow-inner">
                                        <span className="relative flex h-2 w-2">
                                            <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                            <span className="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                                        </span>
                                        <span>Akses Terbuka (Staff Kurikulum)</span>
                                        <button 
                                            onClick={handleLock}
                                            className="ml-2 px-2 py-1 bg-red-600/30 text-red-300 hover:bg-red-600 hover:text-white rounded-lg text-xs font-bold transition"
                                        >
                                            <i className="fa-solid fa-lock mr-1"></i> Kunci
                                        </button>
                                    </div>
                                ) : (
                                    <button 
                                        onClick={() => setShowPinModal(true)}
