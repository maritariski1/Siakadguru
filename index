                                                <th className="py-4 px-6">Catatan</th>
                                                <th className="py-4 px-6">Status Pengumpulan</th>
                                                <th className="py-4 px-6 rounded-tr-xl text-center">Aksi</th>
                                            </tr>
                                        </thead>
                                        <tbody className="divide-y divide-slate-100 text-sm">
                                            {filteredSubmissions.length === 0 ? (
                                                <tr>
                                                    <td colSpan="5" className="py-12 text-center text-slate-400">
                                                        <i className="fa-solid fa-folder-open text-3xl mb-3 block text-slate-300"></i>
                                                        Tidak ada data administrasi pengumpulan yang cocok atau sudah terinput.
                                                    </td>
                                                </tr>
                                            ) : (
                                                filteredSubmissions
                                                    .filter(item => item.category === currentTab)
                                                    .map(item => (
                                                        <tr key={item.id} className="hover:bg-slate-50/80 transition">
                                                            
                                                            {/* User & Class / Subject details */}
                                                            <td className="py-4 px-6">
                                                                <div className="flex flex-col">
                                                                    <span className="font-bold text-slate-800">{item.teacher}</span>
                                                                    {item.subject && (
                                                                        <span className="text-xs text-indigo-600 font-medium mt-0.5">{item.subject}</span>
                                                                    )}
                                                                </div>
                                                            </td>

                                                            {/* Administration type details */}
                                                            <td className="py-4 px-6">
                                                                <div className="flex flex-col">
                                                                    <span className="text-xs font-semibold px-2 py-1 bg-indigo-50 text-indigo-700 rounded-lg w-max mb-1">
                                                                        {item.category === "perangkat" ? "Perangkat" : item.category === "jurnal_mengajar" ? "Jurnal Mengajar" : item.category === "jurnal_walikelas" ? "Jurnal Wali" : "Jurnal Kelas"}
                                                                    </span>
                                                                    <span className="text-slate-600 font-medium">{item.period}</span>
                                                                    {item.class && (
                                                                        <span className="text-xs text-slate-400 mt-0.5">Kelas: <span className="font-bold text-slate-500">{item.class}</span></span>
                                                                    )}
                                                                </div>
                                                            </td>

                                                            {/* Notes/Link */}
                                                            <td className="py-4 px-6 max-w-xs">
                                                                <p className="text-slate-500 text-xs truncate" title={item.notes}>
                                                                    {item.notes || <em className="text-slate-300">Tidak ada catatan</em>}
                                                                </p>
                                                            </td>

                                                            {/* Interactive status badge or direct quick status selector */}
                                                            <td className="py-4 px-6">
                                                                {isUnlocked ? (
                                                                    <div className="flex items-center gap-1">
                                                                        {["Sudah", "Revisi", "Belum"].map(st => (
                                                                            <button 
                                                                                key={st}
                                                                                onClick={() => handleFastStatusUpdate(item, st)}
                                                                                className={`px-2.5 py-1 text-xs font-bold rounded-lg transition border ${
                                                                                    item.status === st 
                                                                                        ? st === "Sudah" 
                                                                                            ? "bg-emerald-100 text-emerald-800 border-emerald-300"
                                                                                            : st === "Revisi"
                                                                                                ? "bg-amber-100 text-amber-800 border-amber-300"
                                                                                                : "bg-red-100 text-red-800 border-red-300"
                                                                                        : "bg-white text-slate-400 border-slate-200 hover:bg-slate-100"
                                                                                }`}
                                                                            >
                                                                                {st}
                                                                            </button>
                                                                        ))}
                                                                    </div>
                                                                ) : (
                                                                    <span className={`px-3 py-1.5 rounded-full text-xs font-bold ${
                                                                        item.status === "Sudah" 
                                                                            ? "bg-emerald-100 text-emerald-800"
                                                                            : item.status === "Revisi"
                                                                                ? "bg-amber-100 text-amber-800"
                                                                                : "bg-red-100 text-red-800"
                                                                    }`}>
                                                                        {item.status}
                                                                    </span>
                                                                )}
                                                            </td>

                                                            {/* Action deletion buttons */}
                                                            <td className="py-4 px-6 text-center">
                                                                <button 
                                                                    onClick={() => handleDeleteRecord(item.id)}
                                                                    className="p-2 text-red-400 hover:text-red-600 transition rounded-lg hover:bg-red-50"
                                                                    title="Hapus data"
                                                                >
                                                                    <i className="fa-solid fa-trash-can"></i>
                                                                </button>
                                                            </td>

                                                        </tr>
                                                    ))
                                            )}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        )}

                    </main>

                    {}
                    {showPinModal && (
                        <div className="fixed inset-0 z-50 overflow-y-auto bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
                            <div className="bg-white rounded-3xl max-w-md w-full p-6 shadow-2xl border border-slate-100 transform transition-all">
                                
                                <div className="text-center mb-6">
                                    <div className="mx-auto w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-4 text-2xl">
                                        <i className="fa-solid fa-key"></i>
                                    </div>
                                    <h3 className="text-xl font-extrabold text-slate-800">Buka Akses Pengisian</h3>
                                    <p className="text-sm text-slate-400 mt-1">Hanya staf kurikulum yang memiliki otorisasi untuk melakukan input atau modifikasi data.</p>
                                </div>

                                <form onSubmit={handleUnlock} className="flex flex-col gap-4">
                                    <div>
                                        <label className="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 text-center">Masukkan PIN Kurikulum</label>
                                        <input 
                                            type="password"
                                            value={pinInput}
                                            onChange={(e) => setPinInput(e.target.value)}
                                            placeholder="••••"
                                            className="w-full text-center tracking-widest text-2xl font-black bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                            maxLength="10"
                                            autoFocus
                                        />
                                        {pinError && (
                                            <p className="text-xs text-red-500 mt-2 text-center font-semibold">
                                                <i className="fa-solid fa-circle-exclamation mr-1"></i>
                                                {pinError}
                                            </p>
                                        )}
                                        <p className="text-[11px] text-slate-400 mt-2 text-center">PIN Default: <strong className="text-indigo-600">2026</strong>. Anda bisa mengubah PIN ini di pojok kanan atas setelah masuk.</p>
                                    </div>

                                    <div className="flex gap-3 mt-2">
                                        <button 
                                            type="button"
                                            onClick={() => { setShowPinModal(false); setPinInput(""); setPinError(""); }}
                                            className="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-3 rounded-xl text-sm transition"
                                        >
                                            Batal
                                        </button>
                                        <button 
                                            type="submit"
                                            className="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl text-sm transition shadow-lg shadow-indigo-600/20"
                                        >
                                            Verifikasi PIN
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    )}

                    {}
                    {showSettingsModal && (
                        <div className="fixed inset-0 z-50 overflow-y-auto bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4">
                            <div className="bg-white rounded-3xl max-w-md w-full p-6 shadow-2xl border border-slate-100 transform transition-all">
                                
                                <div className="text-center mb-6">
                                    <div className="mx-auto w-14 h-14 bg-slate-100 text-slate-700 rounded-2xl flex items-center justify-center mb-4 text-2xl">
                                        <i className="fa-solid fa-gears"></i>
                                    </div>
                                    <h3 className="text-xl font-extrabold text-slate-800">Pengaturan Keamanan</h3>
                                    <p className="text-sm text-slate-400 mt-1">Perbarui PIN verifikasi untuk membatasi pengisian data administrasi.</p>
                                </div>

                                <form onSubmit={handleUpdatePin} className="flex flex-col gap-4">
                                    <div>
                                        <label className="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">PIN Keamanan Baru</label>
                                        <input 
                                            type="text"
                                            value={newPinInput}
                                            onChange={(e) => setNewPinInput(e.target.value)}
                                            placeholder="Masukkan PIN Baru (Min. 4 Digit)"
                                            className="w-full text-center text-lg font-bold bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                            maxLength="15"
                                        />
                                    </div>

                                    <div className="flex gap-3 mt-2">
                                        <button 
                                            type="button"
                                            onClick={() => { setShowSettingsModal(false); setNewPinInput(""); }}
                                            className="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-3 rounded-xl text-sm transition"
                                        >
                                            Batal
                                        </button>
                                        <button 
                                            type="submit"
                                            className="flex-1 bg-slate-900 hover:bg-slate-850 text-white font-bold py-3 rounded-xl text-sm transition shadow-lg"
                                        >
                                            Simpan PIN Baru
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    )}

                    {/* Footer */}
                    <footer className="bg-slate-900 text-slate-400 text-xs py-6 border-t border-slate-800 mt-auto">
                        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-3">
                            <span>Sistem Dashboard Real-time • Tahun Ajaran 2026/2027</span>
                            <span className="flex items-center gap-1.5 text-indigo-400">
                                <i className="fa-solid fa-circle-check text-xs"></i>
                                Terkoneksi dengan Database Cloud Firestore
                            </span>
                        </div>
                    </footer>

                </div>
            );
        }

        // Render React Application
        ReactDOM.createRoot(document.getElementById('root')).render(<App />);
    </script>
</body>
</html>
